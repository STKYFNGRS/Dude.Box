generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js v5 Models ───────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]
  articles       Article[]       @relation("AuthoredArticles")
  bookmarks      Bookmark[]
  pushSubs           PushSubscription[]
  keyPair            UserKeyPair?
  conversations      ConversationMember[]
  sentMessages       DirectMessage[]
  channelMemberships ChannelMember[]
  channelMessages    ChannelMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @id
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialID])
}

// ─── Content Models ──────────────────────────────────────────────────

enum ArticleStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model Article {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  content          String        @db.Text
  excerpt          String?       @db.Text
  featuredImage    String?
  categoryId       String
  authorId         String
  status           ArticleStatus @default(DRAFT)
  publishedAt      DateTime?
  readingTime      Int?
  sourceUrl        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  category  Category   @relation(fields: [categoryId], references: [id])
  author    User       @relation("AuthoredArticles", fields: [authorId], references: [id])
  tags      ArticleTag[]
  bookmarks Bookmark[]

  @@index([slug])
  @@index([status, publishedAt])
  @@index([categoryId])
}

model Category {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  description String?
  icon        String?
  sortOrder   Int    @default(0)

  articles    Article[]
  aiDrafts    AIDraft[]
  newsSources NewsSource[]

  @@index([slug])
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  articles ArticleTag[]

  @@index([slug])
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

// ─── AI Content Pipeline ─────────────────────────────────────────────

enum DraftStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

model AIDraft {
  id               String      @id @default(cuid())
  prompt           String      @db.Text
  generatedContent String      @db.Text
  generatedTitle   String?
  generatedExcerpt String?
  categoryId       String?
  status           DraftStatus @default(PENDING_REVIEW)
  adminNotes       String?     @db.Text
  createdAt        DateTime    @default(now())
  reviewedAt       DateTime?

  category Category? @relation(fields: [categoryId], references: [id])

  @@index([status])
}

model Bookmark {
  userId    String
  articleId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([userId, articleId])
}

// ─── News Aggregation ────────────────────────────────────────────────

model NewsSource {
  id          String   @id @default(cuid())
  name        String
  url         String
  feedUrl     String
  categoryId  String?
  active      Boolean  @default(true)
  lastFetched DateTime?
  createdAt   DateTime @default(now())

  category Category?    @relation(fields: [categoryId], references: [id])
  items    NewsFeedItem[]

  @@unique([feedUrl])
  @@index([active])
}

model NewsFeedItem {
  id          String   @id @default(cuid())
  sourceId    String
  title       String
  url         String
  description String?  @db.Text
  imageUrl    String?
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  source NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, url])
  @@index([publishedAt])
}

// ─── Curated News (AI-Aggregated) ────────────────────────────────────

model CuratedNewsItem {
  id           String   @id @default(cuid())
  title        String
  summary      String   @db.Text
  originalUrl  String
  sourceName   String
  region       String   @default("Global")
  topic        String   @default("General")
  importance   Int      @default(3)
  imageUrl     String?
  curatedAt    DateTime @default(now())
  rawFeedItemId String?

  @@index([curatedAt])
  @@index([topic])
  @@index([importance])
  @@index([region])
}

// ─── Conflict Map & Situational Awareness ────────────────────────────

enum ZoneStatus {
  ACTIVE
  MONITORING
  RESOLVED
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ConflictType {
  WAR
  INSURGENCY
  CIVIL_UNREST
  TERRITORIAL
  CYBER
}

enum EventType {
  CONFLICT
  PROTEST
  DISASTER
  MILITARY
}

enum DataSourceType {
  ACLED
  UCDP
  USGS
  FIRMS
  GDELT
  AI_NEWS
}

model ConflictZone {
  id           String       @id @default(cuid())
  name         String
  description  String?      @db.Text
  lat          Float
  lng          Float
  region       String
  countryCode  String?
  status       ZoneStatus   @default(ACTIVE)
  severity     Severity     @default(MEDIUM)
  baselineRisk Int          @default(50)
  conflictType ConflictType @default(WAR)
  lastUpdated  DateTime     @default(now())
  createdAt    DateTime     @default(now())

  events ConflictEvent[]

  @@index([status])
  @@index([countryCode])
  @@index([region])
}

model ConflictEvent {
  id          String    @id @default(cuid())
  zoneId      String?
  title       String
  description String?   @db.Text
  date        DateTime
  sourceUrl   String?
  severity    Severity  @default(MEDIUM)
  eventType   EventType @default(CONFLICT)
  lat         Float
  lng         Float
  countryCode String?
  source      DataSourceType?
  externalId  String?

  zone ConflictZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@unique([source, externalId])
  @@index([date])
  @@index([eventType])
  @@index([zoneId])
  @@index([countryCode])
}

model CountryBrief {
  id           String   @id @default(cuid())
  countryCode  String   @unique
  ciiScore     Float    @default(0)
  ciiBreakdown Json?
  aiSummary    String?  @db.Text
  topHeadlines Json?
  computedAt   DateTime @default(now())

  @@index([countryCode])
}

model DataLayerSource {
  id                   String         @id @default(cuid())
  name                 String
  apiUrl               String
  type                 DataSourceType
  active               Boolean        @default(true)
  lastFetched          DateTime?
  lastError            String?
  fetchIntervalMinutes Int            @default(30)
  createdAt            DateTime       @default(now())

  @@index([type])
}

// ─── Encrypted Messaging ─────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages DirectMessage[]
}

model ConversationMember {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  ciphertext     String   @db.Text
  iv             String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model UserKeyPair {
  id                  String   @id @default(cuid())
  userId              String   @unique
  publicKey           String   @db.Text
  encryptedPrivateKey String   @db.Text
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Channel Chat (The Conversation) ─────────────────────────────────

model Channel {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  members  ChannelMember[]
  messages ChannelMessage[]

  @@index([slug])
}

model ChannelMember {
  id         String    @id @default(cuid())
  channelId  String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([userId])
}

// ─── Push Notifications ──────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  keysJson  String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
